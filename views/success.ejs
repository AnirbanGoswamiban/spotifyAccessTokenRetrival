<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login Successful</title>
  <style>
    @keyframes blob1 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(60px,-80px) scale(1.15)} 66%{transform:translate(-40px,60px) scale(0.9)} }
    @keyframes blob2 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(-70px,50px) scale(1.2)} 66%{transform:translate(50px,-70px) scale(0.85)} }
    @keyframes blob3 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(40px,80px) scale(0.9)} 66%{transform:translate(-60px,-40px) scale(1.1)} }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @keyframes shimmer { 0%{opacity:0.6} 50%{opacity:1} 100%{opacity:0.6} }

    body {
      margin: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: #0a0010;
      font-family: Arial, sans-serif;
    }

    .lamp-wrap {
      position:relative;
      width:100%;
      height:100vh;
      overflow:hidden;
      display:flex;
      align-items:center;
      justify-content:center;
    }

    .blob {
      position:absolute;
      border-radius:50%;
      filter:blur(60px);
      mix-blend-mode:screen;
    }

    .b1 { width:260px; height:260px; background:#1db954; top:10%; left:10%; animation:blob1 9s infinite; }
    .b2 { width:300px; height:300px; background:#00e5ff; top:40%; left:55%; animation:blob2 11s infinite; }
    .b3 { width:220px; height:220px; background:#7c3aff; bottom:5%; left:20%; animation:blob3 8s infinite; }

    .card {
      position:relative;
      z-index:10;
      text-align:center;
      padding:44px 48px;
      border-radius:24px;
      background:rgba(255,255,255,0.07);
      backdrop-filter:blur(24px);
      border:1px solid rgba(255,255,255,0.15);
      animation:float 4s ease-in-out infinite;
      max-width:340px;
      width:90%;
    }

    .check-ring {
      width:64px;
      height:64px;
      border-radius:50%;
      background:rgba(29,185,84,0.2);
      border:2px solid #1db954;
      display:flex;
      align-items:center;
      justify-content:center;
      margin:0 auto 20px;
      animation:shimmer 2.5s infinite;
    }

    .check-ring svg {
      width:32px;
      height:32px;
      fill:#1db954;
    }

    h1 {
      font-size:26px;
      font-weight:700;
      color:#fff;
      margin:0 0 8px;
    }

    .sub {
      font-size:14px;
      color:rgba(255,255,255,0.6);
      margin-bottom:28px;
    }

    .btn {
      display:inline-block;
      background:#1db954;
      color:#000;
      font-weight:700;
      padding:12px 26px;
      border-radius:50px;
      text-decoration:none;
      transition:0.2s;
    }

    .btn:hover {
      background:#1ed760;
      transform:scale(1.05);
    }
  </style>
</head>
<body>
  <div class="lamp-wrap">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>

    <div class="card">
      <div class="check-ring">
        <svg viewBox="0 0 24 24">
          <path d="M9 16.2l-3.5-3.5-1.4 1.4L9 19 20.3 7.7l-1.4-1.4z"/>
        </svg>
      </div>

      <h1>You're in </h1>
      <p class="sub">Your Spotify account has been successfully connected.</p>

      <a href="/" class="btn">Continue</a>
    </div>
  </div>
</body>
</html>