<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Login with Spotify</title>
  <style>
    @keyframes blob1 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(60px,-80px) scale(1.15)} 66%{transform:translate(-40px,60px) scale(0.9)} }
    @keyframes blob2 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(-70px,50px) scale(1.2)} 66%{transform:translate(50px,-70px) scale(0.85)} }
    @keyframes blob3 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(40px,80px) scale(0.9)} 66%{transform:translate(-60px,-40px) scale(1.1)} }
    @keyframes blob4 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(-50px,-60px) scale(1.1)} 66%{transform:translate(70px,40px) scale(0.95)} }
    @keyframes blob5 { 0%,100%{transform:translate(0,0) scale(1)} 33%{transform:translate(80px,30px) scale(1.05)} 66%{transform:translate(-30px,-80px) scale(1.2)} }
    @keyframes float { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-10px)} }
    @keyframes pulse-ring { 0%{box-shadow:0 0 0 0 rgba(255,255,255,0.3)} 70%{box-shadow:0 0 0 20px rgba(255,255,255,0)} 100%{box-shadow:0 0 0 0 rgba(255,255,255,0)} }
    @keyframes shimmer { 0%{opacity:0.6} 50%{opacity:1} 100%{opacity:0.6} }
    @keyframes grain { 0%,100%{transform:translate(0,0)} 10%{transform:translate(-2%,-3%)} 20%{transform:translate(3%,2%)} 30%{transform:translate(-1%,4%)} 40%{transform:translate(4%,-1%)} 50%{transform:translate(-3%,3%)} 60%{transform:translate(2%,-4%)} 70%{transform:translate(-4%,1%)} 80%{transform:translate(1%,-2%)} 90%{transform:translate(-2%,4%)} }

    body { margin: 0; display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #0a0010; font-family: Arial, sans-serif; }

    .lamp-wrap { position:relative; width:100%; height:100vh; overflow:hidden; display:flex; align-items:center; justify-content:center; }

    .blob { position:absolute; border-radius:50%; filter:blur(60px); mix-blend-mode:screen; }
    .b1 { width:260px; height:260px; background:#ff2d78; top:10%; left:10%; animation:blob1 9s ease-in-out infinite; }
    .b2 { width:300px; height:300px; background:#7c3aff; top:40%; left:55%; animation:blob2 11s ease-in-out infinite; }
    .b3 { width:220px; height:220px; background:#00e5ff; bottom:5%; left:20%; animation:blob3 8s ease-in-out infinite; }
    .b4 { width:200px; height:200px; background:#ff9500; top:5%; right:15%; animation:blob4 13s ease-in-out infinite; }
    .b5 { width:180px; height:180px; background:#1db954; bottom:20%; right:5%; animation:blob5 10s ease-in-out infinite; }
    .b6 { width:240px; height:240px; background:#e040fb; top:50%; left:30%; animation:blob2 7s ease-in-out infinite reverse; }
    .b7 { width:200px; height:200px; background:#00bcd4; top:20%; left:40%; animation:blob1 12s ease-in-out infinite reverse; }

    .noise { position:absolute; inset:0; opacity:0.06; background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E"); animation:grain 0.5s steps(1) infinite; pointer-events:none; }

    .card { position:relative; z-index:10; text-align:center; padding:44px 48px; border-radius:24px; background:rgba(255,255,255,0.07); backdrop-filter:blur(24px); border:1px solid rgba(255,255,255,0.15); animation:float 4s ease-in-out infinite; max-width:340px; width:90%; }

    .logo-ring { width:64px; height:64px; border-radius:50%; background:rgba(29,185,84,0.2); border:2px solid #1db954; display:flex; align-items:center; justify-content:center; margin:0 auto 20px; animation:shimmer 2.5s ease-in-out infinite; }
    .logo-ring svg { width:32px; height:32px; }

    h1 { font-size:26px; font-weight:700; color:#fff; margin:0 0 8px; letter-spacing:-0.5px; }
    .sub { font-size:14px; color:rgba(255,255,255,0.55); margin:0 0 32px; }

    .btn-spotify { display:inline-flex; align-items:center; gap:10px; background:#1db954; color:#000; font-size:15px; font-weight:700; padding:14px 28px; border-radius:50px; text-decoration:none; letter-spacing:0.3px; transition:all 0.2s; animation:pulse-ring 2.5s ease-out infinite; border:none; cursor:pointer; }
    .btn-spotify:hover { background:#1ed760; transform:scale(1.05); }
    .btn-spotify svg { width:20px; height:20px; flex-shrink:0; }

    .dots { display:flex; justify-content:center; gap:6px; margin-top:28px; }
    .dot { width:6px; height:6px; border-radius:50%; animation:shimmer 2s ease-in-out infinite; }
    .dot:nth-child(1){ background:#ff2d78; animation-delay:0s; }
    .dot:nth-child(2){ background:#7c3aff; animation-delay:0.3s; }
    .dot:nth-child(3){ background:#00e5ff; animation-delay:0.6s; }
    .dot:nth-child(4){ background:#ff9500; animation-delay:0.9s; }
    .dot:nth-child(5){ background:#1db954; animation-delay:1.2s; }
  </style>
</head>
<body>
  <div class="lamp-wrap">
    <div class="blob b1"></div>
    <div class="blob b2"></div>
    <div class="blob b3"></div>
    <div class="blob b4"></div>
    <div class="blob b5"></div>
    <div class="blob b6"></div>
    <div class="blob b7"></div>
    <div class="noise"></div>

    <div class="card">
      <div class="logo-ring">
        <svg viewBox="0 0 24 24" fill="#1db954" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 11-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 01.207.857zm1.223-2.72a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.13-9.965-1.166a.78.78 0 01-.973-.517.781.781 0 01.517-.972c3.632-1.102 8.147-.568 11.236 1.326a.78.78 0 01.257 1.072zm.105-2.835c-3.223-1.914-8.54-2.09-11.618-1.156a.935.935 0 11-.543-1.79c3.532-1.072 9.404-.865 13.115 1.338a.935.935 0 01-.954 1.608z"/>
        </svg>
      </div>
      <h1>Welcome back</h1>
      <p class="sub">Connect your Spotify account to continue</p>
      <a href="/login" class="btn-spotify">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12s4.477 10 10 10 10-4.477 10-10S17.523 2 12 2zm4.586 14.424a.623.623 0 01-.857.207c-2.348-1.435-5.304-1.76-8.785-.964a.623.623 0 11-.277-1.215c3.809-.87 7.076-.496 9.712 1.115a.623.623 0 01.207.857zm1.223-2.72a.78.78 0 01-1.072.257c-2.687-1.652-6.785-2.13-9.965-1.166a.78.78 0 01-.973-.517.781.781 0 01.517-.972c3.632-1.102 8.147-.568 11.236 1.326a.78.78 0 01.257 1.072zm.105-2.835c-3.223-1.914-8.54-2.09-11.618-1.156a.935.935 0 11-.543-1.79c3.532-1.072 9.404-.865 13.115 1.338a.935.623 0 01-.954 1.608z"/></svg>
        Login with Spotify
      </a>
      <div class="dots">
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
        <div class="dot"></div>
      </div>
    </div>
  </div>
</body>
</html>